# AI Provider配置: openai 或 gemini
AI_PROVIDER=openai

# OpenAI or Deepsee API配置
OPENAI_API_KEY=your-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1 #此处可以使用Chatgpt or Deepseek api链接

# OpenAI or Deepseek 模型设置
OPENAI_MODEL=gpt-3.5-turbo #此处可使用chatgpt模型 or deepseek模型

# Gemini API配置
GEMINI_API_KEY=your-api-key-here
GEMINI_MODEL=gemini-3-flash-preview

# 服务设置
HOST=0.0.0.0
PORT=5000
DEBUG=True

# 安全设置 (可选)
# ACCESS_TOKEN=your_access_token_here
